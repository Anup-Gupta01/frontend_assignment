# Supabase project credentials
# Get these from: https://supabase.com/dashboard → your project → Settings → API
#
# NEXT_PUBLIC_ prefix means these are safe to expose to the browser.
# The anon key is restricted by Row Level Security (RLS) policies.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only needed if you add server-side auth or admin operations later.
# Never expose this key in the browser or commit it to git.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
